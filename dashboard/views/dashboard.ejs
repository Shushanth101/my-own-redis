<!-- dashboard.ejs -->
<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Redis clone overview and quick operations</p>
    </div>
    <div class="page-actions">
        <label class="auto-refresh-toggle">
            <input type="checkbox" id="auto-refresh-toggle" checked />
            <span class="toggle-track">
                <span class="toggle-thumb"></span>
            </span>
            <span class="toggle-label">Auto-refresh</span>
        </label>
        <button class="btn btn-danger btn-sm" id="flush-all-btn">
            <svg viewBox="0 0 24 24" fill="none" class="btn-icon"><polyline points="3 6 5 6 21 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M19 6l-1 14H6L5 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 11v6M14 11v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            FLUSHALL
        </button>
    </div>
</div>

<!-- Stats cards -->
<section class="stats-grid" id="stats-grid" aria-label="Database statistics">
    <div class="stat-card" id="stat-total-keys">
        <div class="stat-icon stat-icon--blue">
            <svg viewBox="0 0 24 24" fill="none"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="stat-body">
            <span class="stat-value" id="val-total-keys">—</span>
            <span class="stat-label">Total Keys</span>
        </div>
    </div>

    <div class="stat-card" id="stat-string-keys">
        <div class="stat-icon stat-icon--green">
            <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 9h10M7 12h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div class="stat-body">
            <span class="stat-value" id="val-string-keys">—</span>
            <span class="stat-label">String Keys</span>
        </div>
    </div>

    <div class="stat-card" id="stat-list-keys">
        <div class="stat-icon stat-icon--purple">
            <svg viewBox="0 0 24 24" fill="none"><line x1="8" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="8" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="8" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="3" y1="6" x2="3.01" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="12" x2="3.01" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="18" x2="3.01" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
        <div class="stat-body">
            <span class="stat-value" id="val-list-keys">—</span>
            <span class="stat-label">List Keys</span>
        </div>
    </div>

    <div class="stat-card" id="stat-expiring-keys">
        <div class="stat-icon stat-icon--orange">
            <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><polyline points="12 7 12 12 15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="stat-body">
            <span class="stat-value" id="val-expiring-keys">—</span>
            <span class="stat-label">Expiring Keys</span>
        </div>
    </div>
</section>

<!-- Quick operations + Recent keys -->
<div class="dashboard-grid">

    <!-- Quick SET/GET panel -->
    <section class="panel" id="quick-ops-panel" aria-labelledby="quick-ops-title">
        <div class="panel-header">
            <h2 class="panel-title" id="quick-ops-title">Quick Operations</h2>
        </div>
        <div class="panel-body">

            <!-- SET form -->
            <div class="op-group" id="op-set">
                <div class="op-badge op-badge--set">SET</div>
                <div class="op-fields">
                    <input class="input" type="text" id="set-key" placeholder="key" autocomplete="off" />
                    <input class="input" type="text" id="set-value" placeholder="value" autocomplete="off" />
                    <input class="input input--sm" type="number" id="set-ttl" placeholder="TTL (s)" min="0" />
                    <button class="btn btn-primary btn-sm" id="set-btn">Set</button>
                </div>
            </div>

            <div class="op-divider"></div>

            <!-- GET form -->
            <div class="op-group" id="op-get">
                <div class="op-badge op-badge--get">GET</div>
                <div class="op-fields">
                    <input class="input" type="text" id="get-key" placeholder="key" autocomplete="off" />
                    <button class="btn btn-secondary btn-sm" id="get-btn">Get</button>
                </div>
            </div>

            <!-- GET result -->
            <div class="op-result hidden" id="get-result">
                <span class="result-label">Result:</span>
                <code class="result-value" id="get-result-value"></code>
            </div>

        </div>
    </section>

    <!-- Recent keys preview -->
    <section class="panel" id="recent-keys-panel" aria-labelledby="recent-keys-title">
        <div class="panel-header">
            <h2 class="panel-title" id="recent-keys-title">Live Key Snapshot</h2>
            <span class="panel-badge" id="key-count-badge">0 keys</span>
        </div>
        <div class="panel-body panel-body--scroll" id="recent-keys-list">
            <div class="empty-state" id="keys-empty-state">
                <svg viewBox="0 0 24 24" fill="none" class="empty-icon"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                <p>No keys found</p>
            </div>
        </div>
    </section>

</div>

<script src="/js/dashboard.js"></script>
