<!-- lists.ejs -->
<div class="page-header">
    <div>
        <h1 class="page-title">List Operations</h1>
        <p class="page-subtitle">Push, pop, and inspect Redis list keys</p>
    </div>
</div>

<div class="lists-grid">

    <!-- Push operations -->
    <section class="panel" aria-labelledby="push-ops-title">
        <div class="panel-header">
            <h2 class="panel-title" id="push-ops-title">Push Elements</h2>
        </div>
        <div class="panel-body">

            <div class="form-group">
                <label class="form-label" for="push-key">List Key</label>
                <input class="input" type="text" id="push-key" placeholder="mylist" autocomplete="off" />
            </div>

            <div class="form-group">
                <label class="form-label" for="push-values">Values <span class="label-hint">(one per line)</span></label>
                <textarea class="input textarea" id="push-values" rows="4" placeholder="value1&#10;value2&#10;value3"></textarea>
            </div>

            <div class="btn-group">
                <button class="btn btn-primary" id="lpush-btn">
                    <svg viewBox="0 0 24 24" fill="none" class="btn-icon"><polyline points="17 1 21 5 17 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 11V9a4 4 0 0 1 4-4h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="7 23 3 19 7 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 13v2a4 4 0 0 1-4 4H3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    LPUSH
                </button>
                <button class="btn btn-secondary" id="rpush-btn">
                    <svg viewBox="0 0 24 24" fill="none" class="btn-icon"><polyline points="7 1 3 5 7 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 11V9a4 4 0 0 0-4-4H3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="17 23 21 19 17 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 13v2a4 4 0 0 0 4 4h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    RPUSH
                </button>
            </div>

        </div>
    </section>

    <!-- Pop operations -->
    <section class="panel" aria-labelledby="pop-ops-title">
        <div class="panel-header">
            <h2 class="panel-title" id="pop-ops-title">Pop Elements</h2>
        </div>
        <div class="panel-body">

            <div class="form-group">
                <label class="form-label" for="pop-key">List Key</label>
                <input class="input" type="text" id="pop-key" placeholder="mylist" autocomplete="off" />
            </div>

            <div class="btn-group">
                <button class="btn btn-warning" id="lpop-btn">
                    <svg viewBox="0 0 24 24" fill="none" class="btn-icon"><polyline points="17 1 21 5 17 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 11V9a4 4 0 0 1 4-4h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    LPOP
                </button>
                <button class="btn btn-warning" id="rpop-btn">
                    <svg viewBox="0 0 24 24" fill="none" class="btn-icon"><polyline points="7 1 3 5 7 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 11V9a4 4 0 0 0-4-4H3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    RPOP
                </button>
            </div>

            <!-- Pop result -->
            <div class="op-result hidden" id="pop-result">
                <span class="result-label">Popped:</span>
                <code class="result-value" id="pop-result-value"></code>
            </div>

        </div>
    </section>

    <!-- LRANGE viewer -->
    <section class="panel panel--wide" aria-labelledby="lrange-title">
        <div class="panel-header">
            <h2 class="panel-title" id="lrange-title">LRANGE Viewer</h2>
        </div>
        <div class="panel-body">

            <div class="form-row">
                <div class="form-group form-group--grow">
                    <label class="form-label" for="lrange-key">Key</label>
                    <input class="input" type="text" id="lrange-key" placeholder="mylist" autocomplete="off" />
                </div>
                <div class="form-group form-group--sm">
                    <label class="form-label" for="lrange-start">Start</label>
                    <input class="input" type="number" id="lrange-start" value="0" />
                </div>
                <div class="form-group form-group--sm">
                    <label class="form-label" for="lrange-stop">Stop</label>
                    <input class="input" type="number" id="lrange-stop" value="-1" />
                </div>
                <div class="form-group form-group--btn">
                    <label class="form-label">&nbsp;</label>
                    <button class="btn btn-primary" id="lrange-btn">Fetch</button>
                </div>
            </div>

            <!-- List result -->
            <div class="list-result hidden" id="lrange-result">
                <div class="list-result-header">
                    <span class="result-label">Items</span>
                    <span class="list-count" id="lrange-count">0</span>
                </div>
                <ol class="list-items" id="lrange-items"></ol>
            </div>

            <div class="empty-state hidden" id="lrange-empty">
                <p>List is empty or key not found</p>
            </div>

        </div>
    </section>

</div>

<script src="/js/lists.js"></script>
